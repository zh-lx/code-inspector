---
import Layout from '../layouts/Layout.astro';
import DemoHero from '../components/inspector-demo/DemoHero.astro';
import ShortcutPanel from '../components/inspector-demo/ShortcutPanel.astro';
import StepCards from '../components/inspector-demo/StepCards.astro';
import ComplexSyntax from '../components/inspector-demo/ComplexSyntax.astro';
import TryTargets from '../components/inspector-demo/TryTargets.astro';
---

<Layout title="Code Inspector Astro v6 Demo">
  <main class="inspector-demo">
    <section class="inspector-shell" aria-labelledby="inspector-title">
      <DemoHero />
      <ShortcutPanel />
      <StepCards />
      <ComplexSyntax />
      <TryTargets />
    </section>
  </main>
</Layout>

<style is:global>
  button,
  a {
    font: inherit;
  }

  .inspector-demo {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 24px;
    background:
      radial-gradient(circle at top left, rgba(30, 126, 138, 0.16), transparent 32%),
      linear-gradient(135deg, #f7f9fc 0%, #eef6f3 48%, #fff7e8 100%);
  }

  .inspector-shell {
    width: min(1040px, 100%);
  }

  .inspector-badge {
    display: inline-flex;
    margin: 0 0 18px;
    padding: 6px 10px;
    border: 1px solid #b9d8d2;
    border-radius: 999px;
    color: #1c6b73;
    background: #ffffff;
    font-size: 13px;
    font-weight: 700;
  }

  .inspector-hero {
    max-width: 760px;
  }

  .inspector-hero h1 {
    margin: 0;
    color: #111827;
    font-size: clamp(36px, 6vw, 64px);
    line-height: 1.05;
    letter-spacing: 0;
  }

  .inspector-hero p {
    margin: 18px 0 0;
    color: #4b5563;
    font-size: 18px;
    line-height: 1.8;
  }

  .inspector-shortcuts {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .inspector-shortcut {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 12px;
    border: 1px solid #d7e1df;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.84);
  }

  .inspector-shortcut span {
    color: #667085;
    font-size: 13px;
    font-weight: 700;
  }

  .inspector-shortcut kbd {
    min-width: 54px;
    padding: 6px 10px;
    border-radius: 6px;
    color: #ffffff;
    background: #17202f;
    box-shadow: inset 0 -2px 0 rgba(255, 255, 255, 0.16);
    font-family: inherit;
    font-size: 13px;
    font-weight: 700;
    text-align: center;
  }

  .inspector-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    margin-top: 28px;
  }

  .inspector-card {
    min-height: 168px;
    padding: 20px;
    border: 1px solid #dfe8e5;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 16px 40px rgba(23, 32, 47, 0.08);
  }

  .inspector-card span {
    color: #b7791f;
    font-size: 12px;
    font-weight: 800;
  }

  .inspector-card h2 {
    margin: 12px 0 8px;
    color: #17202f;
    font-size: 20px;
  }

  .inspector-card p {
    margin: 0;
    color: #5b6472;
    line-height: 1.7;
  }

  .inspector-complex {
    margin-top: 24px;
    padding: 22px;
    border: 1px solid #dfe8e5;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 16px 40px rgba(23, 32, 47, 0.08);
  }

  .inspector-complex__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
  }

  .inspector-complex__header p {
    margin: 0 0 6px;
    color: #1c6b73;
    font-size: 13px;
    font-weight: 800;
  }

  .inspector-complex__header h2 {
    margin: 0;
    color: #17202f;
    font-size: 24px;
    line-height: 1.25;
  }

  .inspector-complex__header > span {
    flex: 0 0 auto;
    padding: 8px 10px;
    border-radius: 8px;
    color: #694200;
    background: #fff5d6;
    font-size: 13px;
    font-weight: 800;
  }

  .inspector-complex__shortcuts {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
  }

  .inspector-complex__shortcuts kbd {
    min-width: 64px;
    padding: 7px 10px;
    border-radius: 6px;
    color: #ffffff;
    background: #1c6b73;
    font-family: inherit;
    font-size: 13px;
    font-weight: 800;
    text-align: center;
  }

  .inspector-complex__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-top: 18px;
  }

  .inspector-complex-card {
    min-height: 220px;
    padding: 18px;
    border: 1px solid #d7e1df;
    border-radius: 8px;
    background: #ffffff;
  }

  .inspector-complex-card.is-disabled {
    background: #f5f7fa;
  }

  .inspector-complex-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }

  .inspector-complex-card__meta span,
  .inspector-complex-card__meta strong {
    color: #b7791f;
    font-size: 12px;
    font-weight: 800;
  }

  .inspector-complex-card h3 {
    margin: 14px 0 12px;
    color: #17202f;
    font-size: 18px;
    line-height: 1.35;
  }

  .inspector-complex-card ul {
    display: grid;
    gap: 9px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .inspector-complex-card li {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 10px;
    border-radius: 8px;
    background: #f7f9fc;
  }

  .inspector-complex-card li span,
  .inspector-complex-card p {
    margin: 0;
    color: #5b6472;
    line-height: 1.6;
  }

  .inspector-complex-card small {
    color: #1c6b73;
    font-size: 12px;
    font-weight: 800;
  }

  .inspector-targets {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 22px;
  }

  .inspector-targets button,
  .inspector-targets span,
  .inspector-targets a {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 16px;
    border: 1px solid #cad8d4;
    border-radius: 8px;
    color: #17202f;
    background: #ffffff;
    font: inherit;
    font-weight: 700;
    text-decoration: none;
  }

  .inspector-targets button {
    cursor: pointer;
  }

  @media (max-width: 760px) {
    .inspector-demo {
      padding: 32px 16px;
    }

    .inspector-grid {
      grid-template-columns: 1fr;
    }

    .inspector-complex__header {
      display: grid;
    }

    .inspector-complex__header > span {
      width: fit-content;
    }

    .inspector-complex__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
